#!/usr/bin/env bash
# --- SCSS Preview Compiler ---

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
sass_bin="${SASS:-sass}"
out_dir="${1:-${TMPDIR:-/tmp}/scss-compile}"

if ! command -v "$sass_bin" >/dev/null 2>&1; then
  echo "scss-compile: dart-sass not found" >&2
  echo "  after rebuild     : sass is available directly" >&2
  echo "  without rebuild   : nix shell nixpkgs#dart-sass -c scss-compile" >&2
  exit 1
fi

compile() {
  local src="$1" dst="$2"
  echo "scss-compile: $src → $dst"
  mkdir -p "$(dirname "$dst")"
  "$sass_bin" \
    --no-source-map \
    --no-charset \
    --style=expanded \
    "$src" "$dst"
}

compile \
  "${ROOT}/waybar/style.scss" \
  "${out_dir}/waybar/style.css"

echo "scss-compile: OK"
echo "  → ${out_dir}/waybar/style.css"
