#!/usr/bin/env bash
set -euo pipefail

GAP_HELPER="$HOME/.local/bin/hypr-gap-state.sh"
# shellcheck source=$HOME/.local/bin/hypr-gap-state.sh
# shellcheck disable=SC1091
source "$GAP_HELPER"

CONKY_LAUNCHER="${XDG_CONFIG_HOME:-$HOME/.config}/conky/start_edex_conky_compact.sh"
STATE_FILE="$HYPR_CONKY_STATE_FILE"
PANEL_WIDTH=296
LEFT_PANEL_MARGIN=8
RIGHT_PANEL_MARGIN=28

apply_conky_workspace_gaps() {
  local workspace="$1"
  local gaps_in="$2"
  local gaps_out="$3"
  local top right bottom left _

  read -r top right bottom left _ <<<"$gaps_out"
  top=${top:-16}
  right=${right:-16}
  bottom=${bottom:-16}
  left=${left:-16}

  local new_left=$((left + PANEL_WIDTH + LEFT_PANEL_MARGIN))
  local new_right=$((right + PANEL_WIDTH + RIGHT_PANEL_MARGIN))
  local new_gaps_out="${top} ${new_right} ${bottom} ${new_left}"

  hypr_apply_workspace_gaps "$workspace" "$gaps_in" "$new_gaps_out"
}

restore_conky_workspace_state() {
  hypr_restore_workspace_state \
    "$STATE_FILE" \
    "$(hypr_get_global_gap_fallback "general:gaps_out" "$HYPR_GAPS_OUT_FALLBACK")"
}

prepare_conky_overlay() {
  local active_ws workspace gaps_in gaps_out

  hypr_close_rofi_and_restore
  hypr_close_overview

  mapfile -t TARGET_WORKSPACES < <(hypr_list_target_workspaces)
  if [[ ${#TARGET_WORKSPACES[@]} -eq 0 ]]; then
    active_ws="$(hyprctl activeworkspace -j | jq -r '.name // (.id | tostring)')"
    TARGET_WORKSPACES=("$active_ws")
  fi

  hypr_capture_workspace_state "$STATE_FILE" "${TARGET_WORKSPACES[@]}"

  for workspace in "${TARGET_WORKSPACES[@]}"; do
    gaps_in="$(hypr_get_workspace_gaps "$workspace" in)"
    gaps_out="$(hypr_get_workspace_gaps "$workspace" out)"
    if ! apply_conky_workspace_gaps "$workspace" "$gaps_in" "$gaps_out"; then
      restore_conky_workspace_state
      return 1
    fi
  done
}

if hypr_conky_rails_running; then
  hypr_with_ui_lock hypr_stop_conky_rails_and_restore
  exit 0
fi

if [[ ! -r "$CONKY_LAUNCHER" ]]; then
  echo "Conky launcher not found: $CONKY_LAUNCHER" >&2
  exit 1
fi

hypr_with_ui_lock prepare_conky_overlay

if ! bash "$CONKY_LAUNCHER"; then
  hypr_with_ui_lock restore_conky_workspace_state
  exit 1
fi

(
  while hypr_conky_rails_running; do
    sleep 1
  done

  hypr_with_ui_lock restore_conky_workspace_state
) >/dev/null 2>&1 &
