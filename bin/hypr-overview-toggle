#!/usr/bin/env bash
# ==============================================================================
# HYPR-OVERVIEW-TOGGLE (Mutual Exclusion Edition)
# ==============================================================================
# This script toggles the Hyprspace overview while ensuring that other
# conflicting UI components (Rofi Sidebar and Conky Dashboard) are closed.

set -euo pipefail

GAP_HELPER="$HOME/.local/bin/hypr-gap-state.sh"
# shellcheck source=$HOME/.local/bin/hypr-gap-state.sh
source "$GAP_HELPER"

hypr_close_rofi
hypr_stop_conky_rails_and_restore

hyprctl dispatch overview:toggle all
