#!/usr/bin/env bash

# --- Close Workspace Windows ---

WS=$(hyprctl activeworkspace -j | jq '.id')
WINDOWS=$(hyprctl clients -j | jq -r ".[] | select(.workspace.id == $WS) | .address")

if [ -n "$WINDOWS" ]; then
  cmds=""
  for addr in $WINDOWS; do
    cmds+="dispatch closewindow address:$addr; "
  done
  hyprctl --batch "$cmds"
fi
